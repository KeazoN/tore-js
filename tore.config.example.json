{
  "$schema": "./tore.config.schema.json",
  "version": "1.0.0",
  "include": [
    "src/**/*.{ts,tsx}",
    "app/**/*.{ts,tsx}",
    "components/**/*.{ts,tsx}",
    "packages/*/src/**/*.{ts,tsx}"
  ],
  "exclude": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/.next/**",
    "**/coverage/**",
    "**/*.generated.{ts,tsx}"
  ],
  "rules": {
    "noInlineStyle": {
      "severity": "error"
    },
    "noExplicitAny": {
      "severity": "error"
    },
    "forbiddenIntrinsicElements": {
      "severity": "error",
      "elements": {
        "a": "Use Next.js Link or your design-system Link for internal navigation.",
        "button": "Use @/ui/Button (or equivalent) instead of a raw <button>.",
        "img": "Use next/image instead of a raw <img> (LCP and security).",
        "input": "Use @/ui/Input (or your design system input primitive) for form controls.",
        "textarea": "Use @/ui/Textarea for multi-line text.",
        "select": "Use @/ui/Select for dropdowns.",
        "label": "Use @/ui/Label for accessible labels.",
        "iframe": "Use iframes only with an explicit allow-list; prefer a vetted embed component."
      },
      "allowedReplacements": {
        "a": "next/link or @/ui/Link",
        "button": "@/ui/Button",
        "img": "next/image",
        "input": "@/ui/Input",
        "textarea": "@/ui/Textarea",
        "select": "@/ui/Select",
        "label": "@/ui/Label",
        "iframe": "@/ui/IframeEmbed (or a wrapper that matches your security policy)"
      }
    },
    "componentFileLocation": {
      "severity": "warn",
      "include": ["src/**/*.tsx", "app/**/*.tsx"],
      "exclude": [
        "**/*.test.tsx",
        "**/*.spec.tsx",
        "**/*.stories.tsx",
        "**/app/**/layout.tsx",
        "**/app/**/page.tsx",
        "**/app/**/loading.tsx",
        "**/app/**/error.tsx",
        "**/app/**/not-found.tsx",
        "**/app/**/template.tsx",
        "**/pages/**/*.tsx"
      ],
      "allowedPathGlobs": [
        "**/components/**/*.tsx",
        "**/ui/**/*.tsx",
        "**/features/**/components/**/*.tsx"
      ]
    }
  },
  "security": {
    "maskEnvLikeStrings": true
  }
}
